{
  "name": "Viagem",
  "type": "object",
  "properties": {
    "codigo_documento": {
      "type": "string",
      "description": "C\u00f3digo \u00fanico da viagem (gerado automaticamente)"
    },
    "revisao": {
      "type": "string",
      "default": "01",
      "description": "N\u00famero da revis\u00e3o"
    },
    "emissao": {
      "type": "string",
      "format": "date",
      "description": "Data de emiss\u00e3o do documento"
    },
    "ultima_revisao": {
      "type": "string",
      "format": "date",
      "description": "Data da \u00faltima revis\u00e3o"
    },
    "num_pag": {
      "type": "integer",
      "default": 1
    },
    "solicitante_id": {
      "type": "string",
      "description": "ID do colaborador solicitante"
    },
    "solicitante_nome": {
      "type": "string",
      "description": "Nome do solicitante (redundante para consultas)"
    },
    "depto": {
      "type": "string",
      "description": "Departamento do solicitante"
    },
    "dt_saida": {
      "type": "string",
      "format": "date",
      "description": "Data de sa\u00edda da viagem"
    },
    "dt_retorno": {
      "type": "string",
      "format": "date",
      "description": "Data de retorno da viagem"
    },
    "cliente_id": {
      "type": "string",
      "description": "ID do cliente"
    },
    "cliente_nome": {
      "type": "string",
      "description": "Nome do cliente (redundante)"
    },
    "localidade": {
      "type": "string",
      "description": "Cidade/UF do destino"
    },
    "motivo": {
      "type": "string",
      "description": "Motivo da viagem"
    },
    "gestor_id": {
      "type": "string",
      "description": "ID do gestor respons\u00e1vel"
    },
    "gestor_nome": {
      "type": "string",
      "description": "Nome do gestor (redundante)"
    },
    "status": {
      "type": "string",
      "enum": [
        "rascunho",
        "em_andamento",
        "pendente_fechamento",
        "aguardando_gestor",
        "aguardando_financeiro",
        "aprovada",
        "rejeitada"
      ],
      "default": "rascunho",
      "description": "Status atual da viagem"
    },
    "orcamento_previsto": {
      "type": "number",
      "description": "Or\u00e7amento previsto total"
    },
    "vi_adiantamento": {
      "type": "number",
      "default": 0,
      "description": "Valor do adiantamento (VI) recebido"
    },
    "qtd_colaboradores": {
      "type": "integer",
      "default": 1,
      "description": "Quantidade de colaboradores na viagem"
    }
  },
  "required": [
    "solicitante_id",
    "dt_saida",
    "dt_retorno",
    "cliente_id",
    "localidade",
    "motivo"
  ]
}